<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- Header with app logo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/widget_logo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@mipmap/launcher_icon"
            android:contentDescription="WiseSpends Logo" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="WiseSpends"
            android:textColor="#4CAF82"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Visibility toggle button in header -->
        <ImageView
            android:id="@+id/widget_toggle_visibility"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_visibility"
            android:contentDescription="Toggle visibility"
            android:alpha="0.6" />

    </LinearLayout>

    <!-- Quick Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <!-- Expense Button -->
        <FrameLayout
            android:id="@+id/widget_expense_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/widget_action_button_expense"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_expense"
                    android:contentDescription="Expense"
                    android:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Expense"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </FrameLayout>

        <!-- Income Button -->
        <FrameLayout
            android:id="@+id/widget_income_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_action_button_income"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_income"
                    android:contentDescription="Income"
                    android:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Income"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <!-- Last Transaction Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_last_transaction_background"
        android:padding="12dp">

        <!-- Transaction type icon (income/expense/transfer) -->
        <ImageView
            android:id="@+id/widget_transaction_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_transaction"
            android:contentDescription="Transaction Icon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Transaction"
                android:textColor="#806B7280"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_last_transaction_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="No transactions"
                android:textColor="#FF1A1A2E"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Lunch at Restaurant" />

        </LinearLayout>

        <TextView
            android:id="@+id/widget_last_transaction_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RM 0.00"
            android:textColor="#FFFF6B6B"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="RM 45.00" />

    </LinearLayout>

</LinearLayout>